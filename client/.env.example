# AnnaSetu Frontend Environment Variables
# Copy this file to .env and fill in the actual values

# Backend API URL
# For local development: http://localhost:5001
# For production (Vercel): https://annasetu-8a81.onrender.com
REACT_APP_API_URL=https://annasetu-8a81.onrender.com

# Google Maps API Key (optional)
# Get your key from: https://console.cloud.google.com/google/maps-apis
REACT_APP_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Razorpay Key (optional - for payment gateway)
REACT_APP_RAZORPAY_KEY=your_razorpay_key_here
