# AnnaSetu Backend Environment Variables
# Copy this file to .env and fill in the actual values

# MongoDB Connection String
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/AnnaSetu

# Server Port
PORT=5001

# JWT Secret (use a strong random string)
JWT_SECRET=your_jwt_secret_key_here

# Gemini AI API Key (optional - for chatbot features)
GEMINI_API_KEY=your_gemini_api_key_here

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password_here
EMAIL_FROM=AnnaSetu <your_email@gmail.com>

# Frontend URL (for CORS and email links)
# For local development: http://localhost:3000
# For production: https://your-vercel-app.vercel.app
CLIENT_URL=http://localhost:3000

# Node Environment
NODE_ENV=development
