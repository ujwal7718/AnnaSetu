{
  "name": "food-donation-platform",
  "version": "1.0.0",
  "description": "Online food donation platform connecting donors, NGOs, and volunteers",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start",
    "install-client": "cd client && npm install",
    "build-client": "cd client && npm run build",
    "create-admin": "node server/scripts/createAdmin.js"
  },
  "dependencies": {
    "@react-google-maps/api": "^2.20.8",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.0.1",
    "mongoose": "^7.5.0",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "food",
    "donation",
    "ngo",
    "volunteer",
    "mern"
  ],
  "author": "",
  "license": "MIT"
}
